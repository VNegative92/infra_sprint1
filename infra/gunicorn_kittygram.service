[Unit]
Description=gunicorn daemon for Kittygram
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/kittygram/backend
ExecStart=/home/ubuntu/kittygram/backend/venv/bin/gunicorn --bind 127.0.0.1:8080 kittygram_backend.wsgi:application

[Install]
WantedBy=multi-user.target
